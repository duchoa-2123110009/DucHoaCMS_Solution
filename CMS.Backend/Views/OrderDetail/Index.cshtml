@model IEnumerable<CMS.Data.Entities.OrderDetail>
@{
    Layout = "_LayoutAdmin";
}
<h2 class="text-primary">DANH SÁCH CHI TIẾT ĐƠN HÀNG (DỮ LIỆU MẪU)</h2>
<table class="table table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>OrderID</th>
            <th>ProductId</th>
            <th>Số lượng</th>
            <th>UnitPrice</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.OrderId</td>
                <td>@item.ProductId</td>
                <td>@item.Quantity</td>
                <td>@item.UnitPrice</td>
            </tr>
        }
    </tbody>
</table>